# ===========================================
# CostChef - Variables d'environnement (prod)
# ===========================================
# Copier ce fichier en .env et remplir les valeurs

# --- Application ---
APP_HOST=costchef.fr
RAILS_ENV=production
RAILS_LOG_TO_STDOUT=true
RAILS_MASTER_KEY=

# --- Base de données ---
DATABASE_URL=

# --- Mailer ---
MAILER_FROM_ADDRESS=CostChef <noreply@costchef.fr>
MAILER_REPLY_TO=tom.grenie@gmail.com

# --- SMTP (Gmail) ---
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_DOMAIN=costchef.fr
SMTP_USERNAME=
SMTP_PASSWORD=
