<%# Page header %>
<div class="page-header">
  <h1 class="page-title">Référentiel pièces</h1>
  <div style="display: flex; gap: 8px;">
    <%= link_to referentiel_pieces_path(format: :csv), class: "btn-outline-slate" do %>
      <i class="bi bi-file-earmark-spreadsheet"></i> Exporter CSV
    <% end %>
    <%= link_to root_path, class: "btn-accent" do %>
      <i class="bi bi-arrow-left"></i> Dashboard
    <% end %>
  </div>
</div>

<div style="padding: 24px;">
  <div class="section-card">
    <div class="section-header">
      <h2 class="section-title"><i class="bi bi-egg"></i> Produits à l'unité (<%= @piece_products.size %>)</h2>
    </div>

    <% if @piece_products.any? %>
      <div class="table-responsive">
        <table class="data-table">
          <thead>
            <tr>
              <th>Nom</th>
              <th>Poids unitaire (g)</th>
              <th>Poids unitaire (kg)</th>
              <th>Prix moyen (€/kg)</th>
              <th style="width: 50px;"></th>
            </tr>
          </thead>
          <tbody>
            <% @piece_products.each do |product| %>
              <tr>
                <td><%= product.name %></td>
                <td class="mono"><%= number_with_precision(product.unit_weight_kg * 1000, precision: 0) %> g</td>
                <td class="mono"><%= number_with_precision(product.unit_weight_kg, precision: 3) %> kg</td>
                <td class="mono"><%= number_with_precision(product.avg_price_per_kg, precision: 2) %> €</td>
                <td>
                  <%= link_to "#",
                        class: "action-btn",
                        title: "Modifier le poids",
                        data: { controller: "toggle-edit",
                                action: "click->toggle-edit#toggle",
                                toggle_edit_target_param: "edit_piece_#{product.id}" } do %>
                    <i class="bi bi-pencil"></i>
                  <% end %>
                </td>
              </tr>
              <tr id="edit_piece_<%= product.id %>" class="d-none">
                <td colspan="5">
                  <%= form_with model: product, url: product_path(product), method: :patch, local: true do |f| %>
                    <%= hidden_field_tag :return_to, "referentiel_pieces" %>
                    <%= hidden_field_tag :input_unit, "g" %>
                    <div style="display: flex; align-items: center; gap: 8px;">
                      <label class="form-label-xs" style="margin: 0; white-space: nowrap;">Poids (g)</label>
                      <%= f.number_field :unit_weight_kg,
                            value: (product.unit_weight_kg * 1000).round(0),
                            class: "form-control-sm",
                            style: "width: 120px;",
                            step: 1,
                            min: 1 %>
                      <button type="submit" class="btn-slate" style="padding: 4px 12px; font-size: 12px;">Enregistrer</button>
                      <%= link_to "Annuler", "#",
                            class: "btn-outline-slate",
                            style: "padding: 4px 12px; font-size: 12px;",
                            data: { controller: "toggle-edit",
                                    action: "click->toggle-edit#toggle",
                                    toggle_edit_target_param: "edit_piece_#{product.id}" } %>
                    </div>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p style="padding: 24px; text-align: center; color: var(--sl-400);">Aucun produit à l'unité.</p>
    <% end %>
  </div>
</div>
