<%= turbo_frame_tag "product_#{product.id}" do %>
  <div class="product-card">
    <%# Hover actions %>
    <div class="card-actions">
      <%= link_to edit_product_path(product),
            class: "action-btn",
            data: { turbo_frame: "_top" },
            title: "Modifier" do %>
        <i class="bi bi-pencil"></i>
      <% end %>

      <%= button_to product_path(product),
            method: :delete,
            form: { data: { turbo_confirm: "Supprimer ce produit ?", turbo_frame: "_top" } },
            class: "action-btn danger #{'disabled' if product.used_in_recipes?}",
            title: product.used_in_recipes? ? "Utilisé dans #{product.recipes_count} recette(s)" : "Supprimer" do %>
        <i class="bi bi-trash"></i>
      <% end %>
    </div>

    <%# Unit badge %>
    <div class="p-unit"><%= product.base_unit %></div>

    <div class="product-card-badge-slot">
      <% if product.high_variability? %>
        <div class="badge-variability">
          <i class="bi bi-exclamation-triangle-fill"></i> Forte variabilité
        </div>
      <% end %>
    </div>

    <%# Name %>
    <div class="p-name"><%= product.name %></div>

    <%# Price %>
    <% if product.simple_avg_price_per_kg.to_f > 0 || product.avg_price_per_kg.to_f > 0 %>
      <div class="p-price-row">
        <span class="p-price"><span class="p-price-label">PON</span> <%= number_with_precision(product.avg_price_per_kg, precision: 2) %> €/kg</span>
        <span class="p-price-simple"><span class="p-price-label p-price-label--red">MOY</span> <%= number_with_precision(product.simple_avg_price_per_kg, precision: 2) %> €/kg</span>
      </div>
    <% else %>
      <div class="p-price">
        <span class="badge-warning-sl">
          <i class="bi bi-exclamation-triangle"></i> Prix non défini
        </span>
      </div>
    <% end %>

    <%# Meta %>
    <div class="p-meta">
      <%= product.product_purchases.active.count %> conditionnement(s) actif(s)
    </div>

    <%# Stock button: collapse on desktop, link to show on mobile %>
    <button class="stock-btn d-none d-md-block"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#purchases_collapse_<%= product.id %>"
            aria-expanded="false">
      <i class="bi bi-box-seam"></i> Gérer les conditionnements
    </button>
    <%= link_to product_path(product), class: "stock-btn d-md-none", data: { turbo_frame: "_top" } do %>
      <i class="bi bi-box-seam"></i> Gérer les conditionnements
    <% end %>
  </div>
<% end %>
