<%# Page header %>
<div class="page-header">
  <div class="d-flex align-items-center gap-3">
    <h1 class="page-title">Produits</h1>
    <span class="mono" style="color: var(--sl-400);"><%= @products.size %> produit<%= 's' if @products.size > 1 %></span>
  </div>
  <div class="d-flex align-items-center gap-2">
    <%= link_to products_path(format: :csv, search: params[:search]), class: "btn-outline-slate" do %>
      <i class="bi bi-file-earmark-spreadsheet"></i> CSV
    <% end %>
    <%= link_to new_product_path, class: "btn-accent" do %>
      <i class="bi bi-plus-lg"></i> Nouveau produit
    <% end %>
  </div>
</div>

<%# Search bar %>
<div class="search-bar" style="padding: 12px 24px; background: white; border-bottom: 1px solid var(--sl-200);">
  <%= form_with url: products_path, method: :get, class: "d-flex align-items-center gap-2" do |f| %>
    <%= f.text_field :search,
          value: params[:search],
          placeholder: "Rechercher un produit...",
          class: "form-control form-control-sm flex-grow-1 flex-md-grow-0" %>
    <%= f.select :per_page,
          options_for_select(
            [["20 / page", 20], ["50 / page", 50], ["100 / page", 100]],
            params[:per_page]&.to_i || 50
          ),
          {},
          class: "form-select form-select-sm",
          style: "width: auto;",
          onchange: "this.form.submit()" %>
    <%= f.submit "Rechercher", class: "btn-outline-slate" %>
    <% if params[:zero_price] == "1" %>
      <%= link_to products_path(search: params[:search], per_page: params[:per_page]),
            class: "btn-outline-slate",
            style: "color: var(--cc-danger); border-color: var(--cc-danger);" do %>
        <i class="bi bi-exclamation-triangle"></i> Prix non défini <span style="font-weight:600;">✕</span>
      <% end %>
    <% else %>
      <%= link_to products_path(search: params[:search], per_page: params[:per_page], zero_price: "1"),
            class: "btn-outline-slate" do %>
        <i class="bi bi-exclamation-triangle"></i> Prix non défini
      <% end %>
    <% end %>
    <% if params[:search].present? %>
      <%= link_to "✕", products_path(zero_price: params[:zero_price]), class: "btn-outline-slate", style: "color: var(--cc-danger);" %>
    <% end %>
  <% end %>
</div>

<%# Products grid %>
<div style="padding: 24px;">
  <% if @products.any? %>
    <div class="products-grid" id="products_accordion">
      <% @products.each do |product| %>
        <div>
          <%= render "products/product_card", product: product %>

          <div class="collapse" id="purchases_collapse_<%= product.id %>" data-bs-parent="#products_accordion">
            <%= turbo_frame_tag "purchases_#{product.id}" do %>
              <%= render "product_purchases/purchases_section",
                    product: product,
                    purchases: product.product_purchases.order(:created_at),
                    new_purchase: ProductPurchase.new,
                    suppliers: current_user.suppliers.active %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p style="color: var(--sl-400); text-align: center; margin-top: 24px; font-size: 13px;">
      <% if params[:search].present? %>
        Aucun produit trouvé pour "<%= params[:search] %>".
      <% else %>
        Aucun produit pour le moment.
      <% end %>
    </p>
  <% end %>
  <% if @pagy.pages > 1 %>
    <div style="display: flex; justify-content: center; padding: 16px 0;">
      <%== pagy_bootstrap_nav(@pagy) %>
    </div>
  <% end %>
</div>
